// Sample order details
const ordersDB: Record<number, string> = {
  101: "Packing",
  102: "Shipped",
  103: "Delivered",
};

// Modify this as async promise function to check order status
function getOrderStatus(orderId: number): Promise<string> {
  // Return a new Promise to handle asynchronous logic
  return new Promise((resolve, reject) => {
    // Simulate a 1-second delay using setTimeout
    setTimeout(() => {
      if (ordersDB[orderId]) {
        // Resolve with the status if ID exists
        resolve(ordersDB[orderId]);
      } else {
        // Reject with an error message if ID is not found
        reject("Order not found.");
      }
    }, 1000);
  });
}

// Async function to fetch and display order status
async function displayOrderStatus(orderId: number): Promise<void> {
  try {
    // Use await to pause until the promise is settled
    const status = await getOrderStatus(orderId);
    // Log the success message as seen in the sample output image
    console.log(`Order #${orderId} status: ${status}`);
  } catch (error) {
    // Catch rejection and log the error message
    console.log(error);
  }
}

